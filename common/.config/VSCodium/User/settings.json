{
  "workbench.colorTheme": "Rosé Pine Moon",
  "workbench.iconTheme": "vscode-icons",
  // Font
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'JetBrains Mono', monospace",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', monospace",
  "editor.fontWeight": "normal",
  "window.zoomLevel": 1,
  "editor.fontSize": 14,
  "terminal.integrated.fontSize": 14,
  "editor.fontLigatures": true,
  // UI
  "editor.minimap.enabled": false,
  "window.commandCenter": false,
  "editor.scrollbar.horizontal": "auto",
  "editor.scrollbar.vertical": "auto",
  "workbench.sideBar.location": "right",
  "workbench.activityBar.location": "bottom",
  "breadcrumbs.enabled": false,
  // Startup page disable - keep blank window
  "workbench.startupEditor": "none",
  // Files
  "files.autoSave": "onFocusChange",
  // Telemetry
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false,
  // Code
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.suggest.insertMode": "replace",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always",
    "source.removeUnusedImports": "always"
  },
  // Misc
  "workbench.settings.editor": "json",
  "extension.ignoreRecomendations": true,
  // Vim integration
  "vim.enableNeovim": true,
  "vim.leader": "<space>",
  "vim.hlsearch": true,
  "vim.useSystemClipboard": true,
  "vim.incsearch": true,
  "vim.highlightedyank.enable": true,
  "git.autofetch": true,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "vim.statusBarColorControl": true,
  "vim.statusBarColors.normal": [
    "#c4a7e7",
    "#232136"
  ],
  "vim.statusBarColors.insert": [
    "#eb6f92",
    "#232136"
  ],
  "vim.statusBarColors.visual": [
    "#f6c177",
    "#232136"
  ],
  "vim.statusBarColors.visualline": [
    "#f6c177",
    "#232136"
  ],
  "vim.statusBarColors.visualblock": [
    "#a6e3a1",
    "#232136"
  ],
  "vim.statusBarColors.replace": "#ea9a97",
  "vim.statusBarColors.commandlineinprogress": "#c4a7e7",
  "vim.statusBarColors.searchinprogressmode": "#c4a7e7",
  "vim.statusBarColors.easymotionmode": "#c4a7e7",
  "vim.statusBarColors.easymotioninputmode": "#c4a7e7",
  "vim.statusBarColors.surroundinputmode": "#c4a7e7",
  "workbench.colorCustomizations": {
    "statusBar.background": "#232136",
    "statusBar.noFolderBackground": "#232136",
    "statusBar.debuggingBackground": "#232136",
    "statusBar.foreground": "#e0def4",
    "statusBar.debuggingForeground": "#e0def4"
  },
  // Terminal
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "zsh",
      "args": [
        "-l"
      ]
    },
    "tmux": {
      "path": "tmux",
      "args": ["new-session", "-A", "-s", "vscode:${workspaceFolder}"]
    }
  },
  "terminal.integrated.defaultProfile.osx": "tmux",
  "terminal.integrated.inheritEnv": false
}
